{
    "expo": {
        "name": "MobileApp",
        "slug": "MobileApp",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/PuluLogo.png",
        "userInterfaceStyle": "light",
        "splash": {
            "image": "./assets/PuluLogo.png",
            "resizeMode": "contain",
            "backgroundColor": "#FBFBEF"
        },
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#FBFBEF",
                "foregroundImage": "./assets/PuluLogo.png"
            },
            "predictiveBackGestureEnabled": false
        },
        "web": {
            "favicon": "./assets/PuluLogo.png"
        }
    }
}